# Environment Variables — Server 1 (Express + TypeScript)
# Copy ke .env dan isi semua variabel sebelum menjalankan server

# ─── App ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ─── Database (PostgreSQL + PostGIS + TimescaleDB) ────
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/smartawd_db
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── JWT Auth ─────────────────────────────────────────
# JWT_SECRET minimal 32 karakter — generate: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_32_CHAR_SECRET_MINIMUM
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Model Service (Server 2 / src/Model) ─────────────
DECISION_ENGINE_URL=http://localhost:8000
DECISION_ENGINE_TIMEOUT_MS=30000

# ─── Cloudflare R2 ────────────────────────────────────
# Format endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=YOUR_R2_API_TOKEN_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_API_TOKEN_SECRET
R2_BUCKET_NAME=awd-orthomosaic
# R2_PUBLIC_URL hanya perlu diisi jika bucket menggunakan custom domain / public access
R2_PUBLIC_URL=

# GISPROC
GISPROC_API_BASE_URI=http://127.0.0.1:8001

# ─── BMKG Weather API ─────────────────────────────────
# URL base resmi BMKG Open Data. adm4_code per-field diambil dari DB (mst.fields.adm4_code)
BMKG_BASE_URL=https://api.bmkg.go.id/publik/prakiraan-cuaca
